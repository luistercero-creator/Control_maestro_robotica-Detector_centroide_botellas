import socket
import serial
import time

# --- CONFIGURACIONES ---
UPDATE_INTERVAL = 2  # Segundos para enviar Start/Stop a RAPID
ROBOT_IP = "192.168.1.21"
ROBOT_PORT = 8000
PUERTO_ARDUINO = "COM7" # Puerto de tu GIGA R1

# --- CONEXIÓN SOCKET (ROBOTSTUDIO) ---
mi_socket = socket.socket()
try:
    mi_socket.connect((ROBOT_IP, ROBOT_PORT))
    print(f"✔ Conectado a RobotStudio en {ROBOT_IP}:{ROBOT_PORT}")
except Exception as e:
    print("❌ Error conectando a RobotStudio:", e)
    exit(1)

# --- CONEXIÓN SERIAL (ARDUINO) ---
try:
    # timeout pequeño para leer rápido y no bloquear el bucle
    serialArduino = serial.Serial(PUERTO_ARDUINO, 9600, timeout=0.05)
    time.sleep(2) # Espera a que el Arduino se estabilice tras abrir el puerto
    print(f"✔ Conectado a Arduino en {PUERTO_ARDUINO}")
except Exception as e:
    print("❌ Error conectando a Arduino:", e)
    exit(1)

last_time = 0  
pin5_alto = False # Variable para rastrear el estado del pin

print("\n--- SISTEMA LISTO ---")
print("Traduciendo señales de Arduino GIGA a comandos para ABB RobotStudio...")
print("Presiona Ctrl+C en la consola para salir.\n")

try:
    while True:
        # 1. LEER DATOS DE ARDUINO (Vaciando el buffer de entrada)
        while serialArduino.in_waiting > 0:
            try:
                mensaje_entrante = serialArduino.readline().decode('ascii').strip()
                if "PIN5:" in mensaje_entrante:
                    valor_pin = mensaje_entrante.split(":")[1]
                    # Si lee "1", pin5_alto es True. Si lee "0", es False.
                    pin5_alto = (valor_pin == "1") 
            except Exception as e:
                pass # Ignora basura electromagnética en la línea serial

        # 2. LÓGICA DE CONTROL
        # Si el pin está en ALTO (3.3V), mandamos Start. Si no, Stop.
        if pin5_alto:
            command = "Start"
        else:
            command = "Stop"

        # 3. ENVIAR COMANDO AL ROBOT (Respetando el UPDATE_INTERVAL)
        tiempo_actual = time.time()
        if tiempo_actual - last_time > UPDATE_INTERVAL:
            try:
                mi_socket.send(command.encode("utf-8"))
                
                # Imprimir en consola para ver qué está pasando
                estado_texto = "ALTO (3.3V)" if pin5_alto else "BAJO (0V)"
                print(f"[{time.strftime('%H:%M:%S')}] Pin 5: {estado_texto} -> Enviando a RAPID: {command}")
                
            except Exception as e:
                print("❌ Error de red: Se perdió la conexión con RobotStudio.", e)
                break # Sale del bucle si el robot se desconecta
            
            last_time = tiempo_actual

        # Pequeña pausa de 10 milisegundos para no asfixiar el procesador de tu PC
        time.sleep(0.01)

except KeyboardInterrupt:
    print("\nDeteniendo sistema de forma segura...")

finally:
    # --- LIMPIEZA ---
    # Esto asegura que los puertos no queden bloqueados (evita el Error 13)
    mi_socket.close()
    serialArduino.close()
    print("Conexiones cerradas correctamente.")